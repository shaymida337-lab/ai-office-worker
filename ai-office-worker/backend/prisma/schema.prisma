// This is your Prisma schema file
// Run: npx prisma generate && npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  whatsappNumber  String?
  googleId        String?   @unique
  passwordHash    String?
  displayName     String?
  accessToken     String?
  refreshToken    String?
  driveFolder     String?
  driveFolderUrl  String?
  driveFolderId   String?
  sheetsId        String?
  invoiceSheetUrl String?
  invoiceSheetId  String?
  taskSheetUrl    String?
  taskSheetId     String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  documents        Document[]
  logs             Log[]
  supplierPayments SupplierPayment[]
  tasks            Task[]
  alerts           Alert[]
  clients          Client[]

  @@map("users")
}

model Client {
  id                 String   @id @default(cuid())
  userId             String
  name               String
  email              String
  googleAccessToken  String?
  googleRefreshToken String?
  gmailConnected     Boolean  @default(false)
  invoiceSheetId     String?
  invoiceSheetUrl    String?
  taskSheetId        String?
  taskSheetUrl       String?
  driveFolderId      String?
  driveFolderUrl     String?
  color              String?  @default("#3B82F6")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents          Document[]
  supplierPayments   SupplierPayment[]
  tasks              Task[]

  @@map("clients")
}

model Document {
  id              String    @id @default(uuid())
  userId          String
  clientId        String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  gmailMessageId  String
  emailSubject    String?
  emailSender     String?
  emailSenderAddr String?
  receivedAt      DateTime?

  vendorName      String?
  docType         String?   @default("OTHER")
  invoiceNumber   String?
  docDate         DateTime?
  paymentDueDate  DateTime?
  amountPreTax    Float?
  taxAmount       Float?
  totalAmount     Float?
  currency        String?   @default("ILS")

  status          String?   @default("NEW")
  requiresAction  Boolean   @default(false)
  aiConfidence    Float?
  aiNotes         String?

  driveFileId     String?
  driveFileUrl    String?
  sheetsRow       Int?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplierPayments SupplierPayment[]

  @@unique([clientId, gmailMessageId])
  @@map("documents")
}

model SupplierPayment {
  id            String   @id @default(uuid())
  userId        String
  clientId      String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  supplierName  String?
  amount        Float?
  currency      String?  @default("ILS")
  date          DateTime?
  dueDate       DateTime?
  paid          Boolean  @default(false)

  documentId    String?
  document      Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  driveFileId   String?
  driveFileUrl  String?
  invoiceLink   String?

  invoiceHash   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, invoiceHash])
  @@map("supplier_payments")
}

model Task {
  id              String   @id @default(uuid())
  userId          String
  clientId        String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client          Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  gmailMessageId  String?
  title           String
  details         String?
  emailSender     String?
  emailSubject    String?
  action          String?
  status          String   @default("פתוח")
  relatedDoc      String?
  completed       Boolean  @default(false)
  priority        Int      @default(2)
  dueDate         DateTime?
  sheetsRow       Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([clientId, gmailMessageId])
  @@map("tasks")
}

model Alert {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  message   String
  metadata  String?
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("alerts")
}

model Log {
  id          String    @id @default(uuid())
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  level       String?   @default("INFO")
  action      String
  message     String
  metadata    String?
  createdAt   DateTime  @default(now())

  @@map("logs")
}
