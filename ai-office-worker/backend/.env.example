# ─── Database ───────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ─── Server ─────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
JWT_SECRET=change-this-to-a-random-64-char-string

# ─── Google OAuth & APIs ─────────────────────────────────────────────────
# console.cloud.google.com → Create project → Enable: Gmail API, Drive API, Sheets API
# Create OAuth 2.0 Client ID (Web application)
# In Google Cloud Console → Authorized redirect URIs, add EXACTLY:
#   http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local dev:
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Hugging Face Spaces (replace with your space URL):
# GOOGLE_REDIRECT_URI=https://shaymida-ai-office-worker.hf.space/api/auth/google/callback

# ─── AI Provider (pick one or both) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# Options: "openai" | "anthropic"
AI_PROVIDER=anthropic

# ─── Frontend URL ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
