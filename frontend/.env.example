NEXT_PUBLIC_API_URL=http://localhost:4000

# Calendar Engine V1 — defaults OFF; do not enable in production until rollout
NEXT_PUBLIC_CALENDAR_ENGINE_V1_READ=false
NEXT_PUBLIC_CALENDAR_ENGINE_V1_WRITE=false

# Formspree form ID for the landing-page waitlist (the part after formspree.io/f/).
# REQUIRED in production (Netlify + Render env). When missing, the waitlist form
# shows an operational error instead of a fake success — it never drops emails silently.
NEXT_PUBLIC_FORMSPREE_WAITLIST_ID=

# Canonical public site origin used for metadata/canonical URLs (defaults to production domain).
NEXT_PUBLIC_SITE_URL=https://ai-office-worker.com
