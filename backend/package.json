{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "node scripts/build-esbuild.mjs",
    "postbuild": "node scripts/embed-build-info.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "start": "node dist/index.js",
    "test:gmail": "tsx --test src/services/gmail-sync.test.ts src/services/gmailDriveLinkEvidence.test.ts src/services/gmailDriveLinkReviewMirror.test.ts",
    "test:scheduling-stress": "tsx --test src/stress/schedulingConcurrency.stress.test.ts",
    "worker": "tsx src/worker.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:check-drift": "node scripts/check-drift.mjs",
    "db:push": "prisma db push",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@prisma/client": "^6.8.2",
    "@sentry/node": "^10.64.0",
    "axios": "^1.16.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "googleapis": "^148.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "stripe": "^22.3.0",
    "tesseract.js": "^7.0.0",
    "twilio": "^5.13.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.28.0",
    "prisma": "^6.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
