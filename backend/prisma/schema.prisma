// AI Office Worker â€” PostgreSQL for Railway production deployment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String? // null = Google-only account
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization?
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @default("My Business")
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone  String   @default("Asia/Jerusalem")
  currency  String   @default("ILS")
  locale    String   @default("he")
  accountantEmail   String?
  accountantName    String?
  businessName      String?
  businessId        String?
  businessAddress   String?
  greenInvoiceApiKeyId String?
  greenInvoiceApiSecret String?
  greenInvoiceEnv   String?   @default("sandbox")
  greenInvoiceConnectedAt DateTime?
  sendMonthlyReport Boolean  @default(true)
  reportDay         Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrations    Integration[]
  supplierPayments SupplierPayment[]
  tasks           Task[]
  emailMessages   EmailMessage[]
  syncLogs        SyncLog[]
  scanLogs        ScanLog[]
  alerts          Alert[]
  whatsappLogs    WhatsAppLog[]
  customerInvoices CustomerInvoice[]
  socialDrafts    SocialDraft[]
  clients         Client[]
  invoices        Invoice[]
  accountantReports AccountantReport[]
  whatsAppAssistant WhatsAppAssistant?
  whatsAppNotifications WhatsAppNotification[]
  whatsAppConversations WhatsAppConversation[]
  notificationRules NotificationRules?
  leads           Lead[]
  messageTemplates MessageTemplate[]
  messageScans    MessageScan[]
  gmailScanItems  GmailScanItem[]
}

model Client {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  email              String
  domain             String?
  firstSeen          DateTime?
  lastSeen           DateTime?
  whatsappNumber     String?
  googleAccessToken  String?
  googleRefreshToken String?
  gmailConnected     Boolean  @default(false)
  invoiceSheetId     String?
  invoiceSheetUrl    String?
  taskSheetId        String?
  taskSheetUrl       String?
  driveFolderId      String?
  driveFolderUrl     String?
  color              String?  @default("#3B82F6")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  supplierPayments SupplierPayment[]
  tasks            Task[]
  emailMessages    EmailMessage[]
  whatsappLogs     WhatsAppLog[]
  invoices         Invoice[]
  clientWhatsApp   ClientWhatsApp?
  whatsAppMessages WhatsAppMessage[]
  socialAccounts   SocialAccount[]
  socialPosts      SocialPost[]
  socialSettings   SocialSettings?

  @@index([organizationId, isActive])
  @@index([organizationId, whatsappNumber])
  @@index([organizationId, domain])
}

model Integration {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String // gmail | drive | sheets | twilio
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  metadata       String? // JSON: folder IDs, spreadsheet ID, Twilio number
  connectedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, provider])
}

model EmailMessage {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  gmailId        String
  threadId       String?
  subject        String
  fromAddress    String
  snippet        String?
  bodyText       String?
  receivedAt     DateTime
  processedAt    DateTime?
  source         String   @default("gmail") // gmail | whatsapp_forward
  createdAt      DateTime @default(now())

  attachments EmailAttachment[]

  @@unique([organizationId, gmailId])
  @@index([clientId])
  @@index([organizationId, processedAt])
}

model EmailAttachment {
  id             String   @id @default(cuid())
  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  filename       String
  mimeType       String?
  gmailAttachmentId String?
  driveFileId    String?
  driveLink      String?
  createdAt      DateTime @default(now())

  @@index([emailMessageId, gmailAttachmentId])
}

model SupplierPayment {
  id              String    @id @default(cuid())
  organizationId  String
  clientId        String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier        String
  amount          Float
  currency        String    @default("ILS")
  date            DateTime
  dueDate         DateTime?
  paid            Boolean   @default(false)
  documentLink    String? // payment request / document
  invoiceLink     String?
  emailSender     String?
  paymentRequired Boolean   @default(true)
  missingInvoice  Boolean   @default(false)
  duplicateHash   String?
  subject         String?
  source          String    @default("gmail")
  emailMessageId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([organizationId, duplicateHash])
  @@index([organizationId, paid])
  @@index([organizationId, dueDate])
  @@index([organizationId, missingInvoice])
  @@index([organizationId, createdAt])
  @@index([clientId, paid])
}

model CustomerInvoice {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       String
  amount         Float
  currency       String    @default("ILS")
  issueDate      DateTime  @default(now())
  dueDate        DateTime?
  paid           Boolean   @default(false)
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, paid])
  @@index([organizationId, dueDate])
}

model Invoice {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber  String?
  amount         Float
  currency       String   @default("ILS")
  date           DateTime
  dueDate        DateTime?
  status         String   @default("pending")
  description    String?
  driveUrl       String?
  sheetsRow      Int?
  emailId        String?
  fromEmail      String?
  gmailMessageId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status, date])
  @@index([organizationId, createdAt])
  @@index([clientId, date])
  @@index([organizationId, gmailMessageId])
  @@unique([organizationId, clientId, emailId, invoiceNumber])
}

model SocialDraft {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform       String   // facebook | instagram | general
  topic          String
  content        String
  status         String   @default("draft") // draft | approved | posted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status])
}

model SocialAccount {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform    String
  accessToken String
  pageId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, platform])
  @@index([clientId, isActive])
}

model SocialPost {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform      String
  content       String
  imageUrl      String?
  canvaDesignId String?
  scheduledAt   DateTime
  status        String
  approvalToken String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  errorMessage   String?
  retryCount     Int      @default(0)
  analytics      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([approvalToken])
}

model SocialSettings {
  id              String  @id @default(cuid())
  clientId        String  @unique
  client          Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  businessType    String
  brandColors     String?
  brandVoice      String?
  postsPerWeek    Int     @default(3)
  targetAudience  String?
  canvaTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Task {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  supplier       String?
  priority       String   @default("medium") // low | medium | high
  status         String   @default("open") // open | completed
  dueDate        DateTime?
  source         String   @default("gmail")
  emailMessageId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([clientId, status])
}

model SyncLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String // gmail_scan | daily_summary | whatsapp_morning | whatsapp_evening
  status         String // success | error
  emailsProcessed Int     @default(0)
  emailsSaved    Int      @default(0)
  invoicesFound  Int      @default(0)
  paymentsCreated Int     @default(0)
  tasksCreated   Int      @default(0)
  driveUploaded  Int      @default(0)
  sheetsUpdated  Int      @default(0)
  errorsCount    Int      @default(0)
  scanMode       String?
  retryOfId      String?
  nextRetryAt    DateTime?
  errorMessage   String?
  startedAt      DateTime @default(now())
  finishedAt     DateTime?

  @@index([organizationId, type, status, finishedAt])
}

model ScanLog {
  id             String   @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type           String
  status         String
  found          Int      @default(0)
  saved          Int      @default(0)
  errors         String?
  startedAt      DateTime @default(now())
  endedAt        DateTime?

  @@index([orgId, type, status, startedAt])
}

model AccountantReport {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  period         String
  totalIncome    Float
  totalExpenses  Float
  profit         Float
  vatDue         Float
  driveUrl       String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  @@unique([organizationId, period])
  @@index([organizationId, createdAt])
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String // new_invoice | upcoming_payment | missing_invoice | duplicate
  title          String
  body           String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model WhatsAppLog {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  direction      String // inbound | outbound
  body           String
  fromNumber     String?
  toNumber       String?
  aiGenerated    Boolean  @default(false)
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId, clientId, createdAt])
  @@index([clientId, read])
}

model ClientWhatsApp {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phoneNumber     String?
  isConnected     Boolean  @default(false)
  sessionData     String?
  lastSyncAt      DateTime?
  messagesScanned Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  from        String
  to          String?
  body        String
  timestamp   DateTime
  hasInvoice  Boolean  @default(false)
  hasTask     Boolean  @default(false)
  processed   Boolean  @default(false)
  invoiceId   String?
  taskId      String?
  createdAt   DateTime @default(now())

  @@index([clientId, timestamp])
  @@index([clientId, processed])
}

model WhatsAppAssistant {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerPhone        String
  isActive          Boolean  @default(true)
  morningReportTime String   @default("07:30")
  clientDailyTime   String   @default("08:00")
  language          String   @default("he")
  createdAt         DateTime @default(now())
}

model WhatsAppNotification {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  phone          String
  type           String
  message        String
  sentAt         DateTime @default(now())
  isOwner        Boolean  @default(false)

  @@index([organizationId, sentAt])
  @@index([phone, sentAt])
  @@index([phone, type, sentAt])
}

model WhatsAppConversation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phone          String
  clientId       String?
  messages       Json
  lastMessageAt  DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, phone])
  @@index([organizationId, lastMessageAt])
}

model NotificationRules {
  id                    String  @id @default(cuid())
  organizationId        String  @unique
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerMorningReport    Boolean @default(true)
  ownerMorningTime      String  @default("07:30")
  ownerCriticalAlerts   Boolean @default(true)
  clientMorningSummary  Boolean @default(true)
  clientMorningTime     String  @default("08:00")
  clientPaymentReminder Boolean @default(true)
  clientPaymentDaysWait Int     @default(7)
  clientInvoiceFound    Boolean @default(true)
  clientUrgentOnly      Boolean @default(true)
  maxMessagesPerDay     Int     @default(2)
  quietHoursStart       String  @default("21:00")
  quietHoursEnd         String  @default("07:00")
  noMessagesOnSaturday  Boolean @default(true)
  noMessagesOnHolidays  Boolean @default(true)
}

model Lead {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  company         String?
  phone           String?
  email           String?
  whatsapp        String?
  source          String   @default("manual")
  stage           String   @default("חדש")
  estimatedValue  Float    @default(0)
  assignedTo      String?
  tags            String[] @default([])
  notes           String?
  score           Int      @default(0)
  priorityStars   Int      @default(1)
  repliedAt       DateTime?
  lastContactAt   DateTime?
  nextReminderAt  DateTime?
  lastMessageStatus String?
  attachments     String[] @default([])
  messageCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timeline  LeadTimeline[]
  sequences LeadSequence[]

  @@index([organizationId, stage, createdAt])
  @@index([organizationId, source])
  @@index([organizationId, assignedTo])
  @@index([organizationId, nextReminderAt])
  @@index([phone])
  @@index([email])
}

model LeadTimeline {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  content   String
  channel   String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model LeadSequence {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  step            Int
  channel         String
  template        String
  scheduledAt     DateTime
  sentAt          DateTime?
  status          String   @default("pending")
  messageTemplate String?
  createdAt       DateTime @default(now())

  @@index([leadId, status])
  @@index([status, scheduledAt])
}

model MessageTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  channel        String
  content        String
  variables      String[] @default([])
  createdAt      DateTime @default(now())

  @@unique([organizationId, name, channel])
  @@index([organizationId, channel])
}

model MessageScan {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel        String
  externalId     String
  emailMessageId String?
  whatsappLogId  String?
  senderName     String?
  senderEmail    String?
  senderPhone    String?
  subject        String?
  bodyText       String
  occurredAt     DateTime
  contactType    String   @default("other")
  intent         String   @default("other")
  sentiment      String   @default("neutral")
  urgency        String   @default("normal")
  summary        String?
  confidence     Float    @default(0.5)
  rawAnalysis    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, channel, occurredAt])
  @@index([organizationId, contactType, intent])
  @@index([organizationId, urgency, occurredAt])
  @@index([senderEmail])
  @@index([senderPhone])
}

model GmailScanItem {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailMessageId     String?
  gmailMessageId     String
  gmailMessageLink   String
  sender             String
  senderEmail        String?
  subject            String
  occurredAt         DateTime
  amount             Float?
  supplierName       String
  documentType       String
  attachmentFilename String?
  driveFileLink      String?
  confidenceScore    String
  reviewStatus       String   @default("needs_review")
  duplicateKey       String
  decisionReason     String
  rawAnalysis        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([organizationId, duplicateKey])
  @@index([organizationId, reviewStatus, occurredAt])
  @@index([organizationId, documentType, occurredAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, documentType, createdAt])
  @@index([organizationId, reviewStatus, createdAt])
  @@index([gmailMessageId])
  @@index([senderEmail])
}


