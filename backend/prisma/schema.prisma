// AI Office Worker â€” PostgreSQL for Railway production deployment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String? // null = Google-only account
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization?
  helpProgress HelpProgress[]
  assignedWorkCases WorkCase[] @relation("WorkCaseAssignedUser")
  assignedCalendarEvents CalendarEvent[] @relation("CalendarEventAssignedUser")
  createdCalendarEvents CalendarEvent[] @relation("CalendarEventCreatedBy")
  organizationMemberships OrganizationMember[]
  natalieConversationSessions NatalieConversationSession[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String   @default("My Business")
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone  String   @default("Asia/Jerusalem")
  currency  String   @default("ILS")
  locale    String   @default("he")
  businessType String @default("service_business") @map("business_type")
  enabledModules Json @default("[\"crm\",\"invoices\",\"supplier_management\",\"tasks\",\"whatsapp\",\"documents\",\"collections\"]") @map("enabled_modules")
  businessSize String? @map("business_size")
  mainBusinessPain String? @map("main_business_pain")
  onboardingCompleted Boolean @default(true) @map("onboarding_completed")
  accountantEmail   String?
  accountantName    String?
  businessName      String?
  businessId        String?
  businessAddress   String?
  greenInvoiceApiKeyId String?
  greenInvoiceApiSecret String?
  greenInvoiceEnv   String?   @default("sandbox")
  greenInvoiceConnectedAt DateTime?
  sendMonthlyReport Boolean  @default(true)
  reportDay         Int      @default(1)
  businessProfile   String?
  calendarAutonomyJson Json @default("{\"calendarAutonomy\":{\"autoConfirmWhenFullyReady\":false,\"autoSendFollowUp\":false,\"autoSyncGoogleOnConfirm\":true,\"autoCreateFollowUpTask\":true}}") @map("calendar_autonomy_json")
  confidenceThresholdsJson Json? @map("confidence_thresholds_json")
  aiAuditorConfigJson Json? @map("ai_auditor_config_json")
  calendarEngineReadEnabled Boolean @default(false) @map("calendar_engine_read_enabled")
  calendarEngineWriteEnabled Boolean @default(false) @map("calendar_engine_write_enabled")
  calendarEngineGoogleMirrorEnabled Boolean @default(false) @map("calendar_engine_google_mirror_enabled")
  calendarEnginePilotNotes String? @map("calendar_engine_pilot_notes")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrations    Integration[]
  supplierPayments SupplierPayment[]
  tasks           Task[]
  emailMessages   EmailMessage[]
  syncLogs        SyncLog[]
  scanLogs        ScanLog[]
  alerts          Alert[]
  whatsappLogs    WhatsAppLog[]
  customerInvoices CustomerInvoice[]
  socialDrafts    SocialDraft[]
  clients         Client[]
  invoices        Invoice[]
  accountantReports AccountantReport[]
  whatsAppAssistant WhatsAppAssistant?
  whatsAppNotifications WhatsAppNotification[]
  whatsAppConversations WhatsAppConversation[]
  natalieConversationSessions NatalieConversationSession[]
  notificationRules NotificationRules?
  leads           Lead[]
  messageTemplates MessageTemplate[]
  messageScans    MessageScan[]
  gmailScanItems  GmailScanItem[]
  documentReviews FinancialDocumentReview[]
  bankStatements  BankStatement[]
  bankTransactions BankTransaction[]
  helpProgress    HelpProgress[]
  outgoingInvoiceDrafts OutgoingInvoiceDraft[]
  services        Service[]
  appointments    Appointment[]
  deals           Deal[]
  workCases       WorkCase[]
  calendarEvents  CalendarEvent[]
  calendarEventAudits CalendarEventAudit[]
  platformAuditLogs PlatformAuditLog[]
  apiIdempotencyKeys ApiIdempotencyKey[]
  releaseCertificates ReleaseCertificateRecord[]
  workCaseTimelineEntries WorkCaseTimelineEntry[]
  ownerDecisionQueueItems OwnerDecisionQueueItem[]
  members OrganizationMember[]
}

/// Organization-scoped RBAC membership (Phase 2.5).
model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model HelpProgress {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  pageKey        String
  itemType       String
  itemKey        String   @default("main")
  progress       Float    @default(0)
  completed      Boolean  @default(false)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, pageKey, itemType, itemKey])
  @@index([organizationId, pageKey])
  @@index([userId, completed])
}

model Client {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  email              String?
  emailIsPlaceholder Boolean  @default(false)
  domain             String?
  firstSeen          DateTime?
  lastSeen           DateTime?
  whatsappNumber     String?
  googleAccessToken  String?
  googleRefreshToken String?
  gmailConnected     Boolean  @default(false)
  invoiceSheetId     String?
  invoiceSheetUrl    String?
  taskSheetId        String?
  taskSheetUrl       String?
  driveFolderId      String?
  driveFolderUrl     String?
  color              String?  @default("#3B82F6")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  supplierPayments SupplierPayment[]
  tasks            Task[]
  emailMessages    EmailMessage[]
  whatsappLogs     WhatsAppLog[]
  invoices         Invoice[]
  clientWhatsApp   ClientWhatsApp?
  whatsAppMessages WhatsAppMessage[]
  socialAccounts   SocialAccount[]
  socialPosts      SocialPost[]
  socialSettings   SocialSettings?
  appointments     Appointment[]
  deals            Deal[]
  workCases        WorkCase[]
  calendarEvents   CalendarEvent[]

  @@index([organizationId, isActive])
  @@index([organizationId, whatsappNumber])
  @@index([organizationId, domain])
}

model Integration {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String // gmail | drive | sheets | twilio
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  metadata       String? // JSON: folder IDs, spreadsheet ID, Twilio number
  connectedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([organizationId, provider])
}

model EmailMessage {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  gmailId        String
  threadId       String?
  subject        String
  fromAddress    String
  snippet        String?
  bodyText       String?
  receivedAt     DateTime
  processedAt    DateTime?
  source         String   @default("gmail") // gmail | whatsapp_forward
  createdAt      DateTime @default(now())

  attachments EmailAttachment[]

  @@unique([organizationId, gmailId])
  @@index([clientId])
  @@index([organizationId, processedAt])
}

model EmailAttachment {
  id             String   @id @default(cuid())
  emailMessageId String
  emailMessage   EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  filename       String
  mimeType       String?
  gmailAttachmentId String?
  driveFileId    String?
  driveLink      String?
  driveUploadStatus String?
  driveFolderId  String?
  driveClientFolderId String?
  driveSupplierFolderId String?
  driveFolderPath String?
  supplierName   String?
  invoiceMonth   Int?
  invoiceYear    Int?
  createdAt      DateTime @default(now())

  @@index([emailMessageId, gmailAttachmentId])
}

model SupplierPayment {
  id              String    @id @default(cuid())
  organizationId  String
  clientId        String?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier        String
  amount          Float
  currency        String    @default("ILS")
  date            DateTime
  dueDate         DateTime?
  paid            Boolean   @default(false)
  documentLink    String? // payment request / document
  invoiceLink     String?
  driveFileId     String?
  driveFileUrl    String?
  driveUploadStatus String?
  driveFolderId   String?
  driveClientFolderId String?
  driveSupplierFolderId String?
  driveFolderPath String?
  supplierName    String?
  invoiceMonth    Int?
  invoiceYear     Int?
  invoiceNumber   String?
  documentFingerprint String?
  sourceFingerprint   String?
  documentTypeDetailed String?
  supplierTaxId   String?
  amountBeforeVat Float?
  vatAmount       Float?
  totalAmount     Float?
  confidenceScore Float?
  parsedFieldsJson Json?     @map("parsed_fields_json")
  approvalStatus  String    @default("approved")
  sourcesJson     Json?
  emailSender     String?
  paymentRequired Boolean   @default(true)
  missingInvoice  Boolean   @default(false)
  duplicateHash   String?
  subject         String?
  source          String    @default("gmail")
  firstSource     String    @default("gmail")
  lastSource      String    @default("gmail")
  sourceCount     Int       @default(1)
  duplicateDetected Boolean @default(false)
  duplicateReason String?
  firstSeenAt     DateTime  @default(now())
  lastSeenAt      DateTime  @default(now())
  emailMessageId  String?
  normalizedDocumentDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([organizationId, duplicateHash])
  @@unique([organizationId, documentFingerprint])
  @@index([organizationId, paid])
  @@index([organizationId, dueDate])
  @@index([organizationId, missingInvoice])
  @@index([organizationId, duplicateDetected])
  @@index([organizationId, createdAt])
  @@index([organizationId, normalizedDocumentDate])
  @@index([clientId, paid])
}

model FinancialDocumentReview {
  id                  String   @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source              String
  sender              String?
  subject             String?
  fileName            String?
  fileSize            Int?
  sourceFingerprint   String
  documentFingerprint String
  documentType        String
  supplierName        String?
  supplierTaxId       String?
  invoiceNumber       String?
  documentDate        DateTime?
  dueDate             DateTime?
  amountBeforeVat     Float?
  vatAmount           Float?
  totalAmount         Float?
  currency            String   @default("ILS")
  driveFileUrl        String?
  driveUploadStatus   String?
  confidenceScore     Float    @default(0)
  reviewStatus        String   @default("needs_review")
  uncertaintyReason   String?
  parsedFieldsJson    Json?    @map("parsed_fields_json")
  rawAnalysis         Json?
  emailMessageId      String?
  gmailMessageId      String?
  whatsappLogId       String?
  supplierPaymentId   String?
  normalizedDocumentDate DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([organizationId, documentFingerprint], map: "FDR_org_documentFingerprint_key")
  @@index([organizationId, reviewStatus, createdAt], map: "FDR_org_reviewStatus_createdAt_idx")
  @@index([organizationId, source, createdAt], map: "FDR_org_source_createdAt_idx")
  @@index([organizationId, sourceFingerprint], map: "FDR_org_sourceFingerprint_idx")
  @@index([organizationId, normalizedDocumentDate])
}

model CustomerInvoice {
  id             String    @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       String
  amount         Float
  currency       String    @default("ILS")
  issueDate      DateTime  @default(now())
  dueDate        DateTime?
  paid           Boolean   @default(false)
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId, paid])
  @@index([organizationId, dueDate])
}

model OutgoingInvoiceDraft {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status                 String       @default("draft")
  source                 String       @default("natalie")
  customerName           String
  customerEmail          String?
  customerTaxId          String?
  clientId               String?
  description            String
  amount                 Float
  currency               String       @default("ILS")
  issueDate              DateTime?
  dueDate                DateTime?
  proposalJson           Json
  greenInvoiceDocumentId String?
  approvedAt             DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([organizationId, status])
}

model Invoice {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber  String?
  amount         Float
  currency       String   @default("ILS")
  date           DateTime
  dueDate        DateTime?
  status         String   @default("pending")
  description    String?
  driveUrl       String?
  driveFileId    String?
  driveFileUrl   String?
  driveUploadStatus String?
  driveFolderId  String?
  driveClientFolderId String?
  driveSupplierFolderId String?
  driveFolderPath String?
  supplierName   String?
  invoiceMonth   Int?
  invoiceYear    Int?
  sheetsRow      Int?
  emailId        String?
  fromEmail      String?
  gmailMessageId String?
  normalizedDocumentDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status, date])
  @@index([organizationId, createdAt])
  @@index([clientId, date])
  @@index([organizationId, gmailMessageId])
  @@index([organizationId, normalizedDocumentDate])
  @@unique([organizationId, clientId, emailId, invoiceNumber])
}

model BankStatement {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fileName         String
  uploadedAt       DateTime @default(now())
  status           String   @default("processing") // "processing" | "ready" | "error"
  transactionCount Int      @default(0)

  transactions BankTransaction[]

  @@index([organizationId])
}

model BankTransaction {
  id                       String   @id @default(cuid())
  bankStatementId          String
  bankStatement            BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  organizationId           String
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date                     DateTime
  amount                   Float
  description              String?
  direction                String // "credit" | "debit"
  rawData                  String?
  matchStatus              String   @default("unmatched") // "matched" | "suggested" | "unmatched"
  matchedInvoiceId         String?
  matchedSupplierPaymentId String?
  matchConfidence          Float?

  @@index([organizationId])
  @@index([bankStatementId])
}

model SocialDraft {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform       String   // facebook | instagram | general
  topic          String
  content        String
  status         String   @default("draft") // draft | approved | posted
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, status])
}

model SocialAccount {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform    String
  accessToken String
  pageId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, platform])
  @@index([clientId, isActive])
}

model SocialPost {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform      String
  content       String
  imageUrl      String?
  canvaDesignId String?
  scheduledAt   DateTime
  status        String
  approvalToken String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  errorMessage   String?
  retryCount     Int      @default(0)
  analytics      Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([approvalToken])
}

model SocialSettings {
  id              String  @id @default(cuid())
  clientId        String  @unique
  client          Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  businessType    String
  brandColors     String?
  brandVoice      String?
  postsPerWeek    Int     @default(3)
  targetAudience  String?
  canvaTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Task {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workCaseId     String?
  workCase       WorkCase? @relation(fields: [workCaseId], references: [id], onDelete: SetNull)
  calendarEventId String?
  calendarEvent  CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  supplier       String?
  priority       String   @default("medium") // low | medium | high
  status         String   @default("open") // open | completed
  dueDate        DateTime?
  source         String   @default("gmail") // gmail | post_event | manual | decision_rejected
  emailMessageId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, emailMessageId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([clientId, status])
  @@index([workCaseId, status])
}

model SyncLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  type           String // gmail_scan | daily_summary | whatsapp_morning | whatsapp_evening
  status         String // success | partial | error
  emailsProcessed Int     @default(0)
  emailsSaved    Int      @default(0)
  invoicesFound  Int      @default(0)
  paymentsCreated Int     @default(0)
  tasksCreated   Int      @default(0)
  driveUploaded  Int      @default(0)
  sheetsUpdated  Int      @default(0)
  errorsCount    Int      @default(0)
  windowTruncated Boolean  @default(false)
  totalMatched    Int?
  scanMode       String?
  retryOfId      String?
  nextRetryAt    DateTime?
  errorMessage   String?
  startedAt      DateTime @default(now())
  finishedAt     DateTime?

  @@index([organizationId, type, status, finishedAt])
  @@index([organizationId, type, status, startedAt])
  @@index([clientId, type, status, finishedAt])
  @@index([nextRetryAt])
}

model ScanLog {
  id             String   @id @default(cuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type           String
  status         String
  found          Int      @default(0)
  saved          Int      @default(0)
  errors         String?
  startedAt      DateTime @default(now())
  endedAt        DateTime?

  @@index([orgId, type, status, startedAt])
}

model AccountantReport {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  period         String
  totalIncome    Float
  totalExpenses  Float
  profit         Float
  vatDue         Float
  driveUrl       String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  @@unique([organizationId, period])
  @@index([organizationId, createdAt])
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String // new_invoice | upcoming_payment | missing_invoice | duplicate
  title          String
  body           String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())
}

model WhatsAppLog {
  id             String   @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  direction      String // inbound | outbound
  body           String
  fromNumber     String?
  toNumber       String?
  providerMessageSid String?
  mediaCount     Int      @default(0)
  mediaJson      Json?
  aiGenerated    Boolean  @default(false)
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([organizationId, clientId, createdAt])
  @@index([clientId, read])
  @@index([organizationId, direction, mediaCount])
  @@index([organizationId, providerMessageSid])
}

model ClientWhatsApp {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phoneNumber     String?
  isConnected     Boolean  @default(false)
  sessionData     String?
  lastSyncAt      DateTime?
  messagesScanned Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WhatsAppMessage {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  from        String
  to          String?
  body        String
  timestamp   DateTime
  hasInvoice  Boolean  @default(false)
  hasTask     Boolean  @default(false)
  processed   Boolean  @default(false)
  invoiceId   String?
  taskId      String?
  createdAt   DateTime @default(now())

  @@index([clientId, timestamp])
  @@index([clientId, processed])
}

model WhatsAppAssistant {
  id                String   @id @default(cuid())
  organizationId    String   @unique
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerPhone        String
  isActive          Boolean  @default(true)
  morningReportTime String   @default("07:30")
  clientDailyTime   String   @default("08:00")
  language          String   @default("he")
  createdAt         DateTime @default(now())
}

model WhatsAppNotification {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  phone          String
  type           String
  message        String
  sentAt         DateTime @default(now())
  isOwner        Boolean  @default(false)

  @@index([organizationId, sentAt])
  @@index([phone, sentAt])
  @@index([phone, type, sentAt])
}

model WhatsAppConversation {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phone          String
  clientId       String?
  messages       Json
  lastMessageAt  DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, phone])
  @@index([organizationId, lastMessageAt])
}

model NatalieConversationSession {
  id                  String   @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentChannel      String   @default("web_chat")
  structuredHistory   Json     @default("[]")
  pendingAction       Json?
  pendingConfirmation Json?
  interruptionState   Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  lastMessageAt       DateTime @default(now())

  @@index([organizationId, userId, lastMessageAt])
  @@index([organizationId, lastMessageAt])
}

model NotificationRules {
  id                    String  @id @default(cuid())
  organizationId        String  @unique
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ownerMorningReport    Boolean @default(true)
  ownerMorningTime      String  @default("07:30")
  ownerCriticalAlerts   Boolean @default(true)
  clientMorningSummary  Boolean @default(true)
  clientMorningTime     String  @default("08:00")
  clientPaymentReminder Boolean @default(true)
  clientPaymentDaysWait Int     @default(7)
  clientInvoiceFound    Boolean @default(true)
  clientUrgentOnly      Boolean @default(true)
  maxMessagesPerDay     Int     @default(2)
  quietHoursStart       String  @default("21:00")
  quietHoursEnd         String  @default("07:00")
  noMessagesOnSaturday  Boolean @default(true)
  noMessagesOnHolidays  Boolean @default(true)
}

model Lead {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  company         String?
  phone           String?
  email           String?
  whatsapp        String?
  source          String   @default("manual")
  stage           String   @default("חדש")
  estimatedValue  Float    @default(0)
  assignedTo      String?
  tags            String[] @default([])
  notes           String?
  score           Int      @default(0)
  priorityStars   Int      @default(1)
  repliedAt       DateTime?
  lastContactAt   DateTime?
  nextReminderAt  DateTime?
  lastMessageStatus String?
  attachments     String[] @default([])
  messageCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  timeline  LeadTimeline[]
  sequences LeadSequence[]
  deal      Deal?
  workCases WorkCase[]
  calendarEvents CalendarEvent[]

  @@index([organizationId, stage, createdAt])
  @@index([organizationId, source])
  @@index([organizationId, assignedTo])
  @@index([organizationId, nextReminderAt])
  @@index([phone])
  @@index([email])
}

model LeadTimeline {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  content   String
  channel   String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model LeadSequence {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  step            Int
  channel         String
  template        String
  scheduledAt     DateTime
  sentAt          DateTime?
  status          String   @default("pending")
  messageTemplate String?
  createdAt       DateTime @default(now())

  @@index([leadId, status])
  @@index([status, scheduledAt])
}

model MessageTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  channel        String
  content        String
  variables      String[] @default([])
  createdAt      DateTime @default(now())

  @@unique([organizationId, name, channel])
  @@index([organizationId, channel])
}

model MessageScan {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel        String
  externalId     String
  emailMessageId String?
  whatsappLogId  String?
  senderName     String?
  senderEmail    String?
  senderPhone    String?
  subject        String?
  bodyText       String
  occurredAt     DateTime
  contactType    String   @default("other")
  intent         String   @default("other")
  sentiment      String   @default("neutral")
  urgency        String   @default("normal")
  summary        String?
  confidence     Float    @default(0.5)
  rawAnalysis    Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, channel, occurredAt])
  @@index([organizationId, contactType, intent])
  @@index([organizationId, urgency, occurredAt])
  @@index([senderEmail])
  @@index([senderPhone])
}

model GmailScanItem {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailMessageId     String?
  gmailMessageId     String
  gmailMessageLink   String
  sender             String
  senderEmail        String?
  subject            String
  occurredAt         DateTime
  amount             Float?
  supplierName       String
  documentType       String
  attachmentFilename String?
  driveFileLink      String?
  driveUploadStatus  String?
  confidenceScore    String
  reviewStatus       String   @default("needs_review")
  duplicateKey       String
  decisionReason     String
  parsedFieldsJson   Json?    @map("parsed_fields_json")
  rawAnalysis        Json?
  normalizedDocumentDate DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([organizationId, duplicateKey])
  @@index([organizationId, reviewStatus, occurredAt])
  @@index([organizationId, documentType, occurredAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, documentType, createdAt])
  @@index([organizationId, reviewStatus, createdAt])
  @@index([organizationId, normalizedDocumentDate])
  @@index([gmailMessageId])
  @@index([senderEmail])
}

model Service {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int      @default(30)
  price           Float?
  color           String?  @default("#3B82F6")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments Appointment[]
  quoteLines   QuoteLine[]
  calendarEvents CalendarEvent[]

  @@index([organizationId, isActive])
}

model Deal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String?      @unique
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  title          String
  stage          String       @default("open")
  estimatedValue Float        @default(0)
  assignedTo     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quotes Quote[]
  events QuoteEvent[]

  @@index([organizationId, stage])
  @@index([organizationId, updatedAt])
}

model Quote {
  id                     String       @id @default(cuid())
  organizationId         String
  dealId                 String
  deal                   Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  version                Int          @default(1)
  status                 String       @default("draft")
  validUntil             DateTime?
  subtotal               Float        @default(0)
  total                  Float        @default(0)
  currency               String       @default("ILS")
  notes                  String?
  approvalToken          String?      @unique
  sentAt                 DateTime?
  viewedAt               DateTime?
  acceptedAt             DateTime?
  greenInvoiceDocumentId String?
  convertedDraftId       String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  lines  QuoteLine[]
  events QuoteEvent[]

  @@index([organizationId, status])
  @@index([dealId, version])
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  sortOrder   Int      @default(0)

  @@index([quoteId, sortOrder])
}

model QuoteEvent {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
}

model Appointment {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  startTime       DateTime
  durationMinutes Int
  status          String   @default("pending")
  googleEventId   String?
  googleSyncStatus String @default("disabled")
  lastGoogleSyncError String?
  lastGoogleSyncAt DateTime?
  googleSyncAttemptCount Int @default(0)
  nextGoogleSyncRetryAt DateTime?
  source          String?  @default("manual")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId, startTime])
  @@index([organizationId, status])
  @@index([organizationId, googleSyncStatus, nextGoogleSyncRetryAt])
  @@index([clientId])
}

// --- Natalie Calendar Engine (Phase 1) — does not replace Appointment ---

enum CalendarEventStatus {
  draft
  pending_readiness
  confirmed
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum EventSource {
  manual
  ai_chat
  voice
  whatsapp
  email
  booking_page
  migration
  system
}

enum DecisionQueueType {
  confirm_appointment
  reschedule_appointment
  cancel_appointment
  create_invoice_placeholder
  send_follow_up_message
  override_conflict
}

enum DecisionQueueStatus {
  pending
  approved
  rejected
  expired
  superseded
}

enum TimelineEntryType {
  work_case_created
  event_created
  prerequisite_passed
  prerequisite_failed
  approval_requested
  approval_granted
  approval_rejected
  status_changed
  event_completed
  event_no_show
  event_cancelled
  event_rescheduled
  task_spawned
  invoice_requested
  google_sync_success
  google_sync_failed
  note_added
  natalie_command
}

enum WorkCaseStatus {
  open
  in_progress
  completed
  cancelled
}

enum CompletionOutcome {
  completed_success
  completed_early
  no_show
  cancelled_by_customer
  cancelled_by_business
}

enum GoogleSyncStatus {
  skipped
  pending
  synced
  failed
  deleted
}

enum DecisionItemSource {
  manual
  natalie_command
  system
}

enum TimelineActorType {
  user
  system
  natalie
}

model WorkCase {
  id                    String         @id @default(cuid())
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title                 String
  status                WorkCaseStatus @default(open)
  clientId              String?
  client                Client?        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leadId                String?
  lead                  Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUserId        String?
  assignedUser          User?          @relation("WorkCaseAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  source                String         @default("calendar")
  description           String?
  priority              String?
  invoiceDraftRequested Boolean        @default(false)
  closedAt              DateTime?
  closedReason          String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  calendarEvents        CalendarEvent[]
  timelineEntries       WorkCaseTimelineEntry[]
  decisionQueueItems    OwnerDecisionQueueItem[]
  tasks                 Task[]

  @@index([organizationId, status])
  @@index([clientId])
  @@index([assignedUserId])
}

model CalendarEvent {
  id                  String              @id @default(cuid())
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType           String              @default("appointment")
  status              CalendarEventStatus @default(draft)
  title               String?
  startAt             DateTime
  endAt               DateTime
  timezone            String              @default("Asia/Jerusalem")
  workCaseId          String
  workCase            WorkCase            @relation(fields: [workCaseId], references: [id], onDelete: Restrict)
  clientId            String?
  client              Client?             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leadId              String?
  lead                Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUserId      String?
  assignedUser        User?               @relation("CalendarEventAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  serviceId           String?
  service             Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  locationType        String?             @default("office")
  address             String?
  remoteLink          String?
  prerequisitesJson   Json                @default("[]")
  completionNotes     String?
  completionOutcome   CompletionOutcome?
  rescheduledFromId   String?             @unique
  rescheduledFrom     CalendarEvent?      @relation("CalendarEventRescheduleChain", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo       CalendarEvent?      @relation("CalendarEventRescheduleChain")
  googleEventId       String?
  googleSyncStatus    GoogleSyncStatus    @default(skipped)
  lastSyncedAt        DateTime?
  source              EventSource
  internalNotes       String?
  legacyAppointmentId String?             @unique
  createdByUserId     String?
  createdByUser       User?               @relation("CalendarEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  commandSessionId    String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  auditEntries        CalendarEventAudit[]
  timelineEntries     WorkCaseTimelineEntry[]
  decisionQueueItems  OwnerDecisionQueueItem[]
  tasks               Task[]

  @@index([organizationId, startAt])
  @@index([organizationId, status])
  @@index([workCaseId])
  @@index([assignedUserId, startAt])
  @@index([clientId])
}

model CalendarEventAudit {
  id              String              @id @default(cuid())
  calendarEventId String
  calendarEvent   CalendarEvent       @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId     String?
  actorType       TimelineActorType
  action          String
  fromStatus      CalendarEventStatus?
  toStatus        CalendarEventStatus?
  changesJson     Json?
  createdAt       DateTime            @default(now())

  @@index([calendarEventId, createdAt])
  @@index([organizationId, createdAt])
}

/// Immutable platform audit trail — append-only (no application updates/deletes).
model PlatformAuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  correlationId  String?
  actorType      String
  actorId        String?
  entityType     String
  entityId       String
  action         String
  severity       String       @default("info")
  sourceModule   String
  sourceRoute    String?
  beforeState    Json?
  afterState     Json?
  reason         String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, correlationId])
  @@index([organizationId, action])
  @@index([organizationId, actorId])
  @@index([organizationId, severity])
}

/// Phase 2.8 — Release Certificate history (append-only).
model ReleaseCertificateRecord {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  certificateId         String       @unique
  timestamp             DateTime     @default(now())
  commitHash            String?
  deployId              String?
  environment           String
  overallStatus         String
  overallScore          Float
  gateResultsJson       Json         @map("gate_results_json")
  failedGatesJson       Json         @map("failed_gates_json")
  warningGatesJson      Json         @map("warning_gates_json")
  releaseRecommendation String
  explanation           String
  certificateJson       Json         @map("certificate_json")
  createdAt             DateTime     @default(now())

  @@index([organizationId, timestamp])
  @@index([organizationId, overallStatus])
}

model WorkCaseTimelineEntry {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workCaseId      String
  workCase        WorkCase          @relation(fields: [workCaseId], references: [id], onDelete: Cascade)
  calendarEventId String?
  calendarEvent   CalendarEvent?    @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  type            TimelineEntryType
  summary         String
  actorType       TimelineActorType
  actorUserId     String?
  metaJson        Json?
  createdAt       DateTime          @default(now())

  @@index([workCaseId, createdAt])
  @@index([organizationId, createdAt])
}

model OwnerDecisionQueueItem {
  id                  String              @id @default(cuid())
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workCaseId          String
  workCase            WorkCase            @relation(fields: [workCaseId], references: [id], onDelete: Cascade)
  calendarEventId     String?
  calendarEvent       CalendarEvent?      @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  type                DecisionQueueType
  status              DecisionQueueStatus @default(pending)
  title               String
  reason              String?
  preparedPayloadJson Json?
  source              DecisionItemSource
  executionIdempotencyKey String?
  metaJson            Json?
  expiresAt           DateTime?
  resolvedAt          DateTime?
  resolvedByUserId    String?
  resolutionNote      String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([organizationId, status, createdAt])
  @@index([calendarEventId, status])
  @@index([workCaseId, status])
}

model ApiIdempotencyKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routeKey       String
  idempotencyKey String
  requestHash    String
  statusCode     Int?
  responseBodyJson Json?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, routeKey, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([organizationId, routeKey, createdAt])
}

