  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  content   String
  channel   String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

model LeadSequence {
  id              String    @id @default(cuid())
  leadId          String
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  step            Int
  channel         String
  template        String
  scheduledAt     DateTime
  sentAt          DateTime?
  status          String    @default("pending")
  messageTemplate String?
  createdAt       DateTime  @default(now())

  @@index([leadId, status])
  @@index([status, scheduledAt])
}

model MessageTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  channel        String
  content        String
  variables      String[]     @default([])
  createdAt      DateTime     @default(now())

  @@unique([organizationId, name, channel])
  @@index([organizationId, channel])
}

model MessageScan {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel        String
  externalId     String
  emailMessageId String?
  whatsappLogId  String?
  senderName     String?
  senderEmail    String?
  senderPhone    String?
  subject        String?
  bodyText       String
  occurredAt     DateTime
  contactType    String       @default("other")
  intent         String       @default("other")
  sentiment      String       @default("neutral")
  urgency        String       @default("normal")
  summary        String?
  confidence     Float        @default(0.5)
  rawAnalysis    Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, channel, externalId])
  @@index([organizationId, channel, occurredAt])
  @@index([organizationId, contactType, intent])
  @@index([organizationId, urgency, occurredAt])
  @@index([senderEmail])
  @@index([senderPhone])
}

model GmailScanItem {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  emailMessageId         String?
  gmailMessageId         String
  gmailMessageLink       String
  sender                 String
  senderEmail            String?
  subject                String
  occurredAt             DateTime
  amount                 Float?
  supplierName           String
  documentType           String
  attachmentFilename     String?
  driveFileLink          String?
  driveUploadStatus      String?
  confidenceScore        String
  reviewStatus           String       @default("needs_review")
  duplicateKey           String
  decisionReason         String
  parsedFieldsJson       Json?        @map("parsed_fields_json")
  rawAnalysis            Json?
  normalizedDocumentDate DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([organizationId, duplicateKey])
  @@index([organizationId, reviewStatus, occurredAt])
  @@index([organizationId, documentType, occurredAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, documentType, createdAt])
  @@index([organizationId, reviewStatus, createdAt])
  @@index([organizationId, normalizedDocumentDate])
  @@index([gmailMessageId])
  @@index([senderEmail])
}

model Service {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int          @default(30)
  price           Float?
  color           String?      @default("#3B82F6")
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  appointments   Appointment[]
  quoteLines     QuoteLine[]
  calendarEvents CalendarEvent[]
  employeeLinks  ServiceEmployee[]

  @@index([organizationId, isActive])
}

/// Calendar Phase 1 — עובדים ביומן. תור בלי employeeId = היומן של בעל העסק
/// (כל התורים הקיימים), כך שההתנהגות הנוכחית נשמרת אחד-לאחד.
model Employee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  color          String       @default("#3B82F6")
  photoUrl       String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  workingHours EmployeeWorkingHours[]
  vacations    EmployeeVacation[]
  serviceLinks ServiceEmployee[]
  appointments Appointment[]

  @@index([organizationId, isActive])
}

/// שעות עבודה שבועיות לעובד: יום בשבוע (0=ראשון..6=שבת), שעות "HH:MM"
/// בשעון הארגון, והפסקות כמערך JSON [{ start: "HH:MM", end: "HH:MM" }].
model EmployeeWorkingHours {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  startTime  String
  endTime    String
  breaksJson Json     @default("[]")

  @@unique([employeeId, dayOfWeek])
}

/// ימי חופשה לעובד — טווח תאריכים מקומיים "YYYY-MM-DD" (כולל שני הקצוות).
model EmployeeVacation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate      String
  endDate        String
  note           String?
  createdAt      DateTime     @default(now())

  @@index([employeeId, startDate])
  @@index([organizationId])
}

/// אילו עובדים מבצעים כל שירות. שירות בלי שורות = כל העובדים יכולים לבצע.
model ServiceEmployee {
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([serviceId, employeeId])
  @@index([employeeId])
}

model Deal {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String?      @unique
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  title          String
  stage          String       @default("open")
  estimatedValue Float        @default(0)
  assignedTo     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  quotes Quote[]
  events QuoteEvent[]

  @@index([organizationId, stage])
  @@index([organizationId, updatedAt])
}

model Quote {
  id                     String    @id @default(cuid())
  organizationId         String
  dealId                 String
  deal                   Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  version                Int       @default(1)
  status                 String    @default("draft")
  validUntil             DateTime?
  subtotal               Float     @default(0)
  total                  Float     @default(0)
  currency               String    @default("ILS")
  notes                  String?
  approvalToken          String?   @unique
  sentAt                 DateTime?
  viewedAt               DateTime?
  acceptedAt             DateTime?
  greenInvoiceDocumentId String?
  convertedDraftId       String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  lines  QuoteLine[]
  events QuoteEvent[]

  @@index([organizationId, status])
  @@index([dealId, version])
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  serviceId   String?
  service     Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  sortOrder   Int      @default(0)

  @@index([quoteId, sortOrder])
}

model QuoteEvent {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
}

model Appointment {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId               String
  client                 Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId              String?
  service                Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  employeeId             String?
  employee               Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  startTime              DateTime
  durationMinutes        Int
  status                 String       @default("pending")
  googleEventId          String?
  googleSyncStatus       String       @default("disabled")
  lastGoogleSyncError    String?
  lastGoogleSyncAt       DateTime?
  googleSyncAttemptCount Int          @default(0)
  nextGoogleSyncRetryAt  DateTime?
  source                 String?      @default("manual")
  notes                  String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  reminderJobs       AppointmentReminderJob[]
  reminderEvents     AppointmentReminderEvent[]
  attendanceProjection AppointmentAttendanceProjection?

  @@index([organizationId, startTime])
  @@index([organizationId, status])
  @@index([organizationId, googleSyncStatus, nextGoogleSyncRetryAt])
  @@index([clientId])
  @@index([employeeId, startTime])
}

model AppointmentReminderJob {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointmentId     String
  appointment       Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  channel           String
  touchpoint        String
  templateKey       String
  templateVersion   Int          @default(1)
  locale            String       @default("he")
  status            String       @default("pending") // pending | leased | sent | failed | dead_letter | cancelled
  scheduledForUtc   DateTime
  timezone          String
  idempotencyKey    String       @unique
  provider          String?
  providerMessageId String?
  leaseOwner        String?
  leaseExpiresAt    DateTime?
  attemptCount      Int          @default(0)
  maxAttempts       Int          @default(5)
  nextAttemptAt     DateTime?
  timeoutAt         DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  events AppointmentReminderEvent[]

  @@index([status, scheduledForUtc])
  @@index([status, nextAttemptAt])
  @@index([leaseExpiresAt])
  @@index([organizationId, appointmentId, createdAt])
}

model AppointmentReminderEvent {
  id                   String                 @id @default(cuid())
  organizationId       String
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointmentId        String
  appointment          Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  reminderJobId        String?
  reminderJob          AppointmentReminderJob? @relation(fields: [reminderJobId], references: [id], onDelete: SetNull)
  eventType            String
  eventSource          String                 // system | provider_webhook | operator
  actor                String?
  provider             String?
  providerMessageId    String?
  providerEventId      String?
  payloadJsonSanitized Json?
  occurredAtUtc        DateTime
  dedupeKey            String?                @unique
  createdAt            DateTime               @default(now())

  @@index([organizationId, appointmentId, occurredAtUtc])
  @@index([reminderJobId, occurredAtUtc])
  @@index([eventType, occurredAtUtc])
}

model AppointmentAttendanceProjection {
  appointmentId       String       @id
  appointment         Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attendanceState     String       @default("scheduled")
  reminderState       String       @default("reminder_pending")
  confirmationStatus  String       @default("unknown")
  responseChannel     String?
  responseLocale      String?
  lastReminderSentAt  DateTime?
  lastResponseAt      DateTime?
  nextReminderAt      DateTime?
  lastTransitionAt    DateTime     @default(now())
  lastTransitionReason String?
  version             Int          @default(1)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([organizationId, attendanceState])
  @@index([organizationId, reminderState])
}

// --- Natalie Calendar Engine (Phase 1) — does not replace Appointment ---

enum CalendarEventStatus {
  draft
  pending_readiness
  confirmed
  in_progress
  completed
  cancelled
  no_show
  rescheduled
}

enum EventSource {
  manual
  ai_chat
  voice
  whatsapp
  email
  booking_page
  migration
  system
}

enum DecisionQueueType {
  confirm_appointment
  reschedule_appointment
  cancel_appointment
  create_invoice_placeholder
  send_follow_up_message
  override_conflict
}

enum DecisionQueueStatus {
  pending
  approved
  rejected
  expired
  superseded
}

enum TimelineEntryType {
  work_case_created
  event_created
  prerequisite_passed
  prerequisite_failed
  approval_requested
  approval_granted
  approval_rejected
  status_changed
  event_completed
  event_no_show
  event_cancelled
  event_rescheduled
  task_spawned
  invoice_requested
  google_sync_success
  google_sync_failed
  note_added
  natalie_command
}

enum WorkCaseStatus {
  open
  in_progress
  completed
  cancelled
}

enum CompletionOutcome {
  completed_success
  completed_early
  no_show
  cancelled_by_customer
  cancelled_by_business
}

enum GoogleSyncStatus {
  skipped
  pending
  synced
  failed
  deleted
}

enum DecisionItemSource {
  manual
  natalie_command
  system
}

enum TimelineActorType {
  user
  system
  natalie
}

model WorkCase {
  id                    String         @id @default(cuid())
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title                 String
  status                WorkCaseStatus @default(open)
  clientId              String?
  client                Client?        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leadId                String?
  lead                  Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUserId        String?
  assignedUser          User?          @relation("WorkCaseAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  source                String         @default("calendar")
  description           String?
  priority              String?
  invoiceDraftRequested Boolean        @default(false)
  closedAt              DateTime?
  closedReason          String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  calendarEvents     CalendarEvent[]
  timelineEntries    WorkCaseTimelineEntry[]
  decisionQueueItems OwnerDecisionQueueItem[]
  tasks              Task[]

  @@index([organizationId, status])
  @@index([clientId])
  @@index([assignedUserId])
}

model CalendarEvent {
  id                  String              @id @default(cuid())
  organizationId      String
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType           String              @default("appointment")
  status              CalendarEventStatus @default(draft)
  title               String?
  startAt             DateTime
  endAt               DateTime
  timezone            String              @default("Asia/Jerusalem")
  workCaseId          String
  workCase            WorkCase            @relation(fields: [workCaseId], references: [id], onDelete: Restrict)
  clientId            String?
  client              Client?             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leadId              String?
  lead                Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUserId      String?
  assignedUser        User?               @relation("CalendarEventAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  serviceId           String?
  service             Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  locationType        String?             @default("office")
  address             String?
  remoteLink          String?
  prerequisitesJson   Json                @default("[]")
  completionNotes     String?
  completionOutcome   CompletionOutcome?
  rescheduledFromId   String?             @unique
  rescheduledFrom     CalendarEvent?      @relation("CalendarEventRescheduleChain", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo       CalendarEvent?      @relation("CalendarEventRescheduleChain")
  googleEventId       String?
  googleSyncStatus    GoogleSyncStatus    @default(skipped)
  lastSyncedAt        DateTime?
  source              EventSource
  internalNotes       String?
  legacyAppointmentId String?             @unique
  createdByUserId     String?
  createdByUser       User?               @relation("CalendarEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  commandSessionId    String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  auditEntries       CalendarEventAudit[]
  timelineEntries    WorkCaseTimelineEntry[]
  decisionQueueItems OwnerDecisionQueueItem[]
  tasks              Task[]

  @@index([organizationId, startAt])
  @@index([organizationId, status])
  @@index([workCaseId])
  @@index([assignedUserId, startAt])
  @@index([clientId])
}

model CalendarEventAudit {
  id              String               @id @default(cuid())
  calendarEventId String
  calendarEvent   CalendarEvent        @relation(fields: [calendarEventId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId     String?
  actorType       TimelineActorType
  action          String
  fromStatus      CalendarEventStatus?
  toStatus        CalendarEventStatus?
  changesJson     Json?
  createdAt       DateTime             @default(now())

  @@index([calendarEventId, createdAt])
  @@index([organizationId, createdAt])
}

/// Immutable platform audit trail — append-only (no application updates/deletes).
model PlatformAuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  correlationId  String?
  actorType      String
  actorId        String?
  entityType     String
  entityId       String
  action         String
  severity       String       @default("info")
  sourceModule   String
  sourceRoute    String?
  beforeState    Json?
  afterState     Json?
  reason         String?
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, correlationId])
  @@index([organizationId, action])
  @@index([organizationId, actorId])
  @@index([organizationId, severity])
}

/// Phase 2.8 — Release Certificate history (append-only).
model ReleaseCertificateRecord {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  certificateId         String       @unique
  timestamp             DateTime     @default(now())
  commitHash            String?
  deployId              String?
  environment           String
  overallStatus         String
  overallScore          Float
  gateResultsJson       Json         @map("gate_results_json")
  failedGatesJson       Json         @map("failed_gates_json")
  warningGatesJson      Json         @map("warning_gates_json")
  releaseRecommendation String
  explanation           String
  certificateJson       Json         @map("certificate_json")
  createdAt             DateTime     @default(now())

  @@index([organizationId, timestamp])
  @@index([organizationId, overallStatus])
}

model WorkCaseTimelineEntry {
  id              String            @id @default(cuid())
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workCaseId      String
  workCase        WorkCase          @relation(fields: [workCaseId], references: [id], onDelete: Cascade)
  calendarEventId String?
  calendarEvent   CalendarEvent?    @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  type            TimelineEntryType
  summary         String
  actorType       TimelineActorType
  actorUserId     String?
  metaJson        Json?
  createdAt       DateTime          @default(now())

  @@index([workCaseId, createdAt])
  @@index([organizationId, createdAt])
}

model OwnerDecisionQueueItem {
  id                      String              @id @default(cuid())
  organizationId          String
  organization            Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workCaseId              String
  workCase                WorkCase            @relation(fields: [workCaseId], references: [id], onDelete: Cascade)
  calendarEventId         String?
  calendarEvent           CalendarEvent?      @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  type                    DecisionQueueType
  status                  DecisionQueueStatus @default(pending)
  title                   String
  reason                  String?
  preparedPayloadJson     Json?
  source                  DecisionItemSource
  executionIdempotencyKey String?
  metaJson                Json?
  expiresAt               DateTime?
  resolvedAt              DateTime?
  resolvedByUserId        String?
  resolutionNote          String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([organizationId, status, createdAt])
  @@index([calendarEventId, status])
  @@index([workCaseId, status])
}

model ApiIdempotencyKey {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  routeKey         String
  idempotencyKey   String
  requestHash      String
  statusCode       Int?
  responseBodyJson Json?
  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, routeKey, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([organizationId, routeKey, createdAt])
}

/// Phase 1 — Communication Core trace layer (append-oriented; idempotent on channel + externalMessageId).
model CommunicationEvent {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel           String
  direction         String
  externalMessageId String
  correlationId     String
  sender            String?
  recipient         String?
  subject           String?
  bodyPreview       String?
  metadataJson      Json?
  sourceReference   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([organizationId, channel, externalMessageId])
  @@index([organizationId, createdAt])
  @@index([organizationId, correlationId])
  @@index([organizationId, channel])
  @@index([externalMessageId])
}

// לידים שיווקיים של נטלי עצמה (מהאתר הציבורי) — נפרד בכוונה מ-Lead,
// שהוא CRM פר-ארגון של לקוחות. אין organizationId ואין קשר ל-tenant.
model MarketingLead {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String
  businessType String
  note         String?
  planInterest String?
  source       String?
  medium       String?
  campaign     String?
  landingPath  String?
  consent      Boolean  @default(false)
  status       String   @default("new")
  createdAt    DateTime @default(now())

  events MarketingLeadEvent[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([email])
}

// אירועי ליד שיווקי — היסטוריית סטטוסים והערות תפעוליות (אדמין פלטפורמה בלבד)
model MarketingLeadEvent {
  id        String        @id @default(cuid())
  leadId    String
  lead      MarketingLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  detail    String?
  createdBy String?
  createdAt DateTime      @default(now())

  @@index([leadId, createdAt])
}
