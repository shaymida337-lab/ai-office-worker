// AI Office Worker â€” PostgreSQL for Railway production deployment.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String? // null = Google-only account
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization                Organization?
  helpProgress                HelpProgress[]
  assignedWorkCases           WorkCase[]                   @relation("WorkCaseAssignedUser")
  assignedCalendarEvents      CalendarEvent[]              @relation("CalendarEventAssignedUser")
  createdCalendarEvents       CalendarEvent[]              @relation("CalendarEventCreatedBy")
  organizationMemberships     OrganizationMember[]
  natalieConversationSessions NatalieConversationSession[]
}

model Organization {
  id                                String    @id @default(cuid())
  name                              String    @default("My Business")
  userId                            String    @unique
  user                              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  timezone                          String    @default("Asia/Jerusalem")
  currency                          String    @default("ILS")
  locale                            String    @default("he")
  language                          String    @default("he")
  country                           String    @default("IL")
  dateFormat                        String    @default("dd/MM/yyyy") @map("date_format")
  timeFormat                        String    @default("24h") @map("time_format")
  weekStart                         String    @default("sunday") @map("week_start")
  phoneCountryCode                  String    @default("+972") @map("phone_country_code")
  businessType                      String    @default("service_business") @map("business_type")
  enabledModules                    Json      @default("[\"crm\",\"invoices\",\"supplier_management\",\"tasks\",\"whatsapp\",\"documents\",\"collections\"]") @map("enabled_modules")
  businessSize                      String?   @map("business_size")
  mainBusinessPain                  String?   @map("main_business_pain")
  onboardingCompleted               Boolean   @default(true) @map("onboarding_completed")
  accountantEmail                   String?
  accountantName                    String?
  businessName                      String?
  businessId                        String?
  businessAddress                   String?
  greenInvoiceApiKeyId              String?
  greenInvoiceApiSecret             String?
  greenInvoiceEnv                   String?   @default("sandbox")
  greenInvoiceConnectedAt           DateTime?
  sendMonthlyReport                 Boolean   @default(true)
  reportDay                         Int       @default(1)
  businessProfile                   String?
  calendarAutonomyJson              Json      @default("{\"calendarAutonomy\":{\"autoConfirmWhenFullyReady\":false,\"autoSendFollowUp\":false,\"autoSyncGoogleOnConfirm\":true,\"autoCreateFollowUpTask\":true}}") @map("calendar_autonomy_json")
  confidenceThresholdsJson          Json?     @map("confidence_thresholds_json")
  aiAuditorConfigJson               Json?     @map("ai_auditor_config_json")
  calendarEngineReadEnabled         Boolean   @default(false) @map("calendar_engine_read_enabled")
  calendarEngineWriteEnabled        Boolean   @default(false) @map("calendar_engine_write_enabled")
  calendarEngineGoogleMirrorEnabled Boolean   @default(false) @map("calendar_engine_google_mirror_enabled")
  calendarEnginePilotNotes          String?   @map("calendar_engine_pilot_notes")
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt

  integrations                Integration[]
  supplierPayments            SupplierPayment[]
  tasks                       Task[]
  emailMessages               EmailMessage[]
  syncLogs                    SyncLog[]
  scanLogs                    ScanLog[]
  alerts                      Alert[]
  whatsappLogs                WhatsAppLog[]
  customerInvoices            CustomerInvoice[]
  socialDrafts                SocialDraft[]
  clients                     Client[]
  clientNotes                 ClientNote[]
  invoices                    Invoice[]
  accountantReports           AccountantReport[]
  whatsAppAssistant           WhatsAppAssistant?
  whatsAppNotifications       WhatsAppNotification[]
  whatsAppConversations       WhatsAppConversation[]
  natalieConversationSessions NatalieConversationSession[]
  notificationRules           NotificationRules?
  leads                       Lead[]
  messageTemplates            MessageTemplate[]
  messageScans                MessageScan[]
  gmailScanItems              GmailScanItem[]
  documentReviews             FinancialDocumentReview[]
  bankStatements              BankStatement[]
  bankTransactions            BankTransaction[]
  helpProgress                HelpProgress[]
  outgoingInvoiceDrafts       OutgoingInvoiceDraft[]
  services                    Service[]
  appointments                Appointment[]
  employees                   Employee[]
  employeeVacations           EmployeeVacation[]
  deals                       Deal[]
  workCases                   WorkCase[]
  calendarEvents              CalendarEvent[]
  calendarEventAudits         CalendarEventAudit[]
  platformAuditLogs           PlatformAuditLog[]
  apiIdempotencyKeys          ApiIdempotencyKey[]
  releaseCertificates         ReleaseCertificateRecord[]
  workCaseTimelineEntries     WorkCaseTimelineEntry[]
  ownerDecisionQueueItems     OwnerDecisionQueueItem[]
  members                     OrganizationMember[]
  communicationEvents         CommunicationEvent[]
  knowledgeDocuments          KnowledgeDocument[]
  reliabilityEvents           ReliabilityEvent[]
  jobRuns                     JobRun[]
  appointmentReminderJobs     AppointmentReminderJob[]
  appointmentReminderEvents   AppointmentReminderEvent[]
  appointmentAttendanceStates AppointmentAttendanceProjection[]
}

/// Natalie Reliability Center V1 — persistent, aggregated production incident store.
/// Failures must live in DB (not console-only) so Natalie can detect, self-heal,
/// and summarize health before customers report bugs.
model ReliabilityEvent {
  id                 String        @id @default(cuid())
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId             String?
  module             String
  severity           String // info | warning | error | critical
  errorCode          String
  userVisibleMessage String?
  technicalMessage   String?
  route              String?
  component          String?
  job                String?
  correlationId      String?
  status             String        @default("open") // open | resolved
  fingerprint        String
  firstSeenAt        DateTime      @default(now())
  lastSeenAt         DateTime      @default(now())
  resolvedAt         DateTime?
  occurrences        Int           @default(1)
  autoHealed         Boolean       @default(false)
  customerVisible    Boolean       @default(false)
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([fingerprint, status], map: "reliability_events_fingerprint_status_idx")
  @@index([organizationId, status, lastSeenAt], map: "reliability_events_org_status_lastSeen_idx")
  @@index([organizationId, module, status], map: "reliability_events_org_module_status_idx")
  @@index([severity, status, lastSeenAt], map: "reliability_events_severity_status_lastSeen_idx")
  @@index([errorCode, status], map: "reliability_events_errorCode_status_idx")
  @@index([customerVisible, status, lastSeenAt], map: "reliability_events_customer_visible_idx")
  @@map("reliability_events")
}

/// Natalie Business Memory (Phase 1–2): unified, organization-scoped business
/// document store. Every source (manual upload, Google Drive, future CRM/Gmail)
/// maps into these rows. Future phases add OCR text, AI summaries, and semantic
/// search on top of the same table.
model KnowledgeDocument {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // manual | google_drive | knowledge — which adapter registered this row
  source String @default("manual")

  // contract | agreement | warranty | quotation | manual | license | certificate | other
  category String  @default("other")
  title    String
  fileName String?

  // Suppliers/customers are not first-class entities in this schema, so we keep
  // denormalized names (matching the existing supplier-as-string convention) and
  // an optional clientId pointer for future joins.
  clientId      String?
  customerName  String?
  supplierName  String?
  supplierTaxId String?

  tags String[] @default([])

  // Storage: canonical pointer plus Google Drive fields (reusing the naming the
  // rest of the codebase uses). Future OCR/semantic columns land on this model.
  storageLocation String?
  driveUrl        String?
  driveFileId     String?

  // Extensible per-source payload (Drive mimeType, folder path, sync revision…)
  metadata Json?

  createdById   String?
  createdByName String?

  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([organizationId])
  @@index([organizationId, category])
  @@index([organizationId, clientId])
  @@index([organizationId, source])
  @@index([organizationId, driveFileId])
  @@map("knowledge_documents")
}

/// Organization-scoped RBAC membership (Phase 2.5).
model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model HelpProgress {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  pageKey        String
  itemType       String
  itemKey        String   @default("main")
  progress       Float    @default(0)
  completed      Boolean  @default(false)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, pageKey, itemType, itemKey])
  @@index([organizationId, pageKey])
  @@index([userId, completed])
}

model Client {
  id                 String       @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  email              String?
  emailIsPlaceholder Boolean      @default(false)
  domain             String?
  firstSeen          DateTime?
  lastSeen           DateTime?
  whatsappNumber     String?
  phone              String?
  address            String?
  googleAccessToken  String?
  googleRefreshToken String?
  gmailConnected     Boolean      @default(false)
  invoiceSheetId     String?
  invoiceSheetUrl    String?
  taskSheetId        String?
  taskSheetUrl       String?
  driveFolderId      String?
  driveFolderUrl     String?
  color              String?      @default("#3B82F6")
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  supplierPayments SupplierPayment[]
  tasks            Task[]
  emailMessages    EmailMessage[]
  whatsappLogs     WhatsAppLog[]
  invoices         Invoice[]
  clientWhatsApp   ClientWhatsApp?
  whatsAppMessages WhatsAppMessage[]
  socialAccounts   SocialAccount[]
  socialPosts      SocialPost[]
  socialSettings   SocialSettings?
  appointments     Appointment[]
  deals            Deal[]
  workCases        WorkCase[]
  calendarEvents   CalendarEvent[]
  clientNotes      ClientNote[]

  @@index([organizationId, isActive])
  @@index([organizationId, whatsappNumber])
  @@index([organizationId, domain])
}

/// כרטיס לקוח — הערות חופשיות ללקוח (בסיס; לא Timeline מלא).
model ClientNote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime     @default(now())

  @@index([organizationId, clientId, createdAt])
}

model Integration {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String // gmail | drive | sheets | twilio
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  metadata       String? // JSON: folder IDs, spreadsheet ID, Twilio number
  connectedAt    DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, provider])
}

model EmailMessage {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  gmailId        String
  threadId       String?
  subject        String
  fromAddress    String
  snippet        String?
  bodyText       String?
  receivedAt     DateTime
  processedAt    DateTime?
  source         String       @default("gmail") // gmail | whatsapp_forward
  createdAt      DateTime     @default(now())

  attachments EmailAttachment[]

  @@unique([organizationId, gmailId])
  @@index([clientId])
  @@index([organizationId, processedAt])
}

model EmailAttachment {
  id                    String       @id @default(cuid())
  emailMessageId        String
  emailMessage          EmailMessage @relation(fields: [emailMessageId], references: [id], onDelete: Cascade)
  filename              String
  mimeType              String?
  gmailAttachmentId     String?
  driveFileId           String?
  driveLink             String?
  driveUploadStatus     String?
  driveFolderId         String?
  driveClientFolderId   String?
  driveSupplierFolderId String?
  driveFolderPath       String?
  supplierName          String?
  invoiceMonth          Int?
  invoiceYear           Int?
  createdAt             DateTime     @default(now())

  @@index([emailMessageId, gmailAttachmentId])
}

model SupplierPayment {
  id                     String       @id @default(cuid())
  organizationId         String
  clientId               String?
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                 Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier               String
  amount                 Float
  currency               String       @default("ILS")
  date                   DateTime
  dueDate                DateTime?
  paid                   Boolean      @default(false)
  documentLink           String? // payment request / document
  invoiceLink            String?
  driveFileId            String?
  driveFileUrl           String?
  driveUploadStatus      String?
  driveFolderId          String?
  driveClientFolderId    String?
  driveSupplierFolderId  String?
  driveFolderPath        String?
  supplierName           String?
  invoiceMonth           Int?
  invoiceYear            Int?
  invoiceNumber          String?
  documentFingerprint    String?
  sourceFingerprint      String?
  documentTypeDetailed   String?
  supplierTaxId          String?
  amountBeforeVat        Float?
  vatAmount              Float?
  totalAmount            Float?
  confidenceScore        Float?
  parsedFieldsJson       Json?        @map("parsed_fields_json")
  approvalStatus         String       @default("approved")
  sourcesJson            Json?
  emailSender            String?
  paymentRequired        Boolean      @default(true)
  missingInvoice         Boolean      @default(false)
  duplicateHash          String?
  subject                String?
  source                 String       @default("gmail")
  firstSource            String       @default("gmail")
  lastSource             String       @default("gmail")
  sourceCount            Int          @default(1)
  duplicateDetected      Boolean      @default(false)
  duplicateReason        String?
  firstSeenAt            DateTime     @default(now())
  lastSeenAt             DateTime     @default(now())
  emailMessageId         String?
  normalizedDocumentDate DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([organizationId, duplicateHash])
  @@unique([organizationId, documentFingerprint])
  @@index([organizationId, paid])
  @@index([organizationId, dueDate])
  @@index([organizationId, missingInvoice])
  @@index([organizationId, duplicateDetected])
  @@index([organizationId, createdAt])
  @@index([organizationId, normalizedDocumentDate])
  @@index([clientId, paid])
}

model FinancialDocumentReview {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source                 String
  sender                 String?
  subject                String?
  fileName               String?
  fileSize               Int?
  sourceFingerprint      String
  documentFingerprint    String
  documentType           String
  supplierName           String?
  supplierTaxId          String?
  invoiceNumber          String?
  documentDate           DateTime?
  dueDate                DateTime?
  amountBeforeVat        Float?
  vatAmount              Float?
  totalAmount            Float?
  currency               String       @default("ILS")
  driveFileUrl           String?
  driveUploadStatus      String?
  confidenceScore        Float        @default(0)
  reviewStatus           String       @default("needs_review")
  uncertaintyReason      String?
  parsedFieldsJson       Json?        @map("parsed_fields_json")
  rawAnalysis            Json?
  emailMessageId         String?
  gmailMessageId         String?
  whatsappLogId          String?
  supplierPaymentId      String?
  normalizedDocumentDate DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([organizationId, documentFingerprint], map: "FDR_org_documentFingerprint_key")
  @@index([organizationId, reviewStatus, createdAt], map: "FDR_org_reviewStatus_createdAt_idx")
  @@index([organizationId, source, createdAt], map: "FDR_org_source_createdAt_idx")
  @@index([organizationId, sourceFingerprint], map: "FDR_org_sourceFingerprint_idx")
  @@index([organizationId, normalizedDocumentDate])
}

model CustomerInvoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       String
  amount         Float
  currency       String       @default("ILS")
  issueDate      DateTime     @default(now())
  dueDate        DateTime?
  paid           Boolean      @default(false)
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, paid])
  @@index([organizationId, dueDate])
}

model OutgoingInvoiceDraft {
  id                     String       @id @default(cuid())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status                 String       @default("draft")
  source                 String       @default("natalie")
  customerName           String
  customerEmail          String?
  customerTaxId          String?
  clientId               String?
  description            String
  amount                 Float
  currency               String       @default("ILS")
  issueDate              DateTime?
  dueDate                DateTime?
  proposalJson           Json
  greenInvoiceDocumentId String?
  approvedAt             DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([organizationId, status])
}

model Invoice {
  id                     String       @id @default(cuid())
  clientId               String
  client                 Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber          String?
  amount                 Float
  currency               String       @default("ILS")
  date                   DateTime
  dueDate                DateTime?
  status                 String       @default("pending")
  description            String?
  driveUrl               String?
  driveFileId            String?
  driveFileUrl           String?
  driveUploadStatus      String?
  driveFolderId          String?
  driveClientFolderId    String?
  driveSupplierFolderId  String?
  driveFolderPath        String?
  supplierName           String?
  invoiceMonth           Int?
  invoiceYear            Int?
  sheetsRow              Int?
  emailId                String?
  fromEmail              String?
  gmailMessageId         String?
  normalizedDocumentDate DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([organizationId, clientId, emailId, invoiceNumber])
  @@index([organizationId, status, date])
  @@index([organizationId, createdAt])
  @@index([clientId, date])
  @@index([organizationId, gmailMessageId])
  @@index([organizationId, normalizedDocumentDate])
}

model BankStatement {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fileName         String
  uploadedAt       DateTime     @default(now())
  status           String       @default("processing") // "processing" | "ready" | "error"
  transactionCount Int          @default(0)

  transactions BankTransaction[]

  @@index([organizationId])
}

model BankTransaction {
  id                       String        @id @default(cuid())
  bankStatementId          String
  bankStatement            BankStatement @relation(fields: [bankStatementId], references: [id], onDelete: Cascade)
  organizationId           String
  organization             Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date                     DateTime
  amount                   Float
  description              String?
  direction                String // "credit" | "debit"
  rawData                  String?
  matchStatus              String        @default("unmatched") // "matched" | "suggested" | "unmatched"
  matchedInvoiceId         String?
  matchedSupplierPaymentId String?
  matchConfidence          Float?

  @@index([organizationId])
  @@index([bankStatementId])
}

model SocialDraft {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform       String // facebook | instagram | general
  topic          String
  content        String
  status         String       @default("draft") // draft | approved | posted
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
}

model SocialAccount {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform    String
  accessToken String
  pageId      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([clientId, platform])
  @@index([clientId, isActive])
}

model SocialPost {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform      String
  content       String
  imageUrl      String?
  canvaDesignId String?
  scheduledAt   DateTime
  status        String
  approvalToken String?
  approvedAt    DateTime?
  publishedAt   DateTime?
  errorMessage  String?
  retryCount    Int       @default(0)
  analytics     Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clientId, scheduledAt])
  @@index([status, scheduledAt])
  @@index([approvalToken])
}

model SocialSettings {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  businessType    String
  brandColors     String?
  brandVoice      String?
  postsPerWeek    Int      @default(3)
  targetAudience  String?
  canvaTemplateId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Task {
  id              String         @id @default(cuid())
  organizationId  String
  clientId        String?
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workCaseId      String?
  workCase        WorkCase?      @relation(fields: [workCaseId], references: [id], onDelete: SetNull)
  calendarEventId String?
  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  supplier        String?
  priority        String         @default("medium") // low | medium | high
  status          String         @default("open") // open | completed
  dueDate         DateTime?
  source          String         @default("gmail") // gmail | post_event | manual | decision_rejected
  emailMessageId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([organizationId, emailMessageId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([clientId, status])
  @@index([workCaseId, status])
}

model SyncLog {
  id              String       @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId        String?
  type            String // gmail_scan | daily_summary | whatsapp_morning | whatsapp_evening
  status          String // success | partial | error
  emailsProcessed Int          @default(0)
  emailsSaved     Int          @default(0)
  invoicesFound   Int          @default(0)
  paymentsCreated Int          @default(0)
  tasksCreated    Int          @default(0)
  driveUploaded   Int          @default(0)
  sheetsUpdated   Int          @default(0)
  errorsCount     Int          @default(0)
  windowTruncated Boolean      @default(false)
  totalMatched    Int?
  scanMode        String?
  retryOfId       String?
  nextRetryAt     DateTime?
  errorMessage    String?
  startedAt       DateTime     @default(now())
  /**
   * Heartbeat for stuck-scan recovery — bumped by progress writes and stage touches.
   */
  updatedAt       DateTime     @default(now()) @updatedAt
  finishedAt      DateTime?

  @@index([organizationId, type, status, finishedAt])
  @@index([organizationId, type, status, startedAt])
  @@index([clientId, type, status, finishedAt])
  @@index([nextRetryAt])
}

model JobRun {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobType        String
  referenceId    String?
  status         String        @default("running") // running | completed | failed | timeout
  startedAt      DateTime      @default(now())
  heartbeatAt    DateTime      @default(now())
  timeoutAt      DateTime
  completedAt    DateTime?
  errorMessage   String?
  retryCount     Int           @default(0)
  maxRetries     Int           @default(0)
  payloadJson    Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, timeoutAt])
  @@index([organizationId, jobType, status])
  @@index([jobType, startedAt])
  @@index([jobType, referenceId, status])
}

model ScanLog {
  id           String       @id @default(cuid())
  orgId        String
